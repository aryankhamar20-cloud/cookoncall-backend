# ═══════════════════════════════════════════════════════
# COOKONCALL BACKEND — ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your real values
# ═══════════════════════════════════════════════════════

# ─── APP ──────────────────────────────────────────────
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# ─── DATABASE (Supabase PostgreSQL) ──────────────────
# Go to: supabase.com → Project → Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres.[YOUR_PROJECT_REF]:[YOUR_DB_PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

# ─── REDIS (Upstash) ─────────────────────────────────
# Go to: console.upstash.com → Create Redis Database → Details tab
REDIS_URL=rediss://default:[YOUR_UPSTASH_PASSWORD]@[YOUR_UPSTASH_ENDPOINT]:6379

# ─── JWT ──────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=PASTE_YOUR_64_CHAR_RANDOM_STRING_HERE
JWT_REFRESH_SECRET=PASTE_ANOTHER_64_CHAR_RANDOM_STRING_HERE
JWT_EXPIRES_IN=15m

# ─── GOOGLE OAUTH ────────────────────────────────────
# Go to: console.cloud.google.com → APIs & Services → Credentials → Create OAuth 2.0 Client
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── RAZORPAY ────────────────────────────────────────
# Go to: dashboard.razorpay.com → Settings → API Keys → Generate Test Key
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ─── MSG91 (OTP & SMS) ───────────────────────────────
# Go to: msg91.com → Dashboard → API Keys
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_OTP_TEMPLATE_ID=your_otp_template_id
MSG91_SMS_TEMPLATE_ID=your_sms_template_id

# ─── CLOUDINARY (Image uploads) ──────────────────────
# Go to: cloudinary.com → Dashboard → Account Details
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── SMTP (Email via Gmail) ──────────────────────────
# Go to: myaccount.google.com → Security → 2-Step Verification → App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_16_char_app_password
SMTP_FROM=noreply@cookoncall.in

# ─── FCM (Firebase Cloud Messaging) ──────────────────
# Go to: console.firebase.google.com → Project Settings → Cloud Messaging → Server Key
FCM_SERVER_KEY=your_fcm_server_key_here

# ─── BREVO (Transactional Email) ─────────────────────
# Already configured above — this reminder is for completeness
# BREVO_API_KEY is the primary email sending mechanism (not SMTP)
BREVO_API_KEY=your_brevo_api_key_here

# ─── WHATSAPP (Meta Cloud API) ───────────────────────
# Used for chef booking-request approvals (chef receives the request
# with Approve/Decline quick-reply buttons) + booking confirmations
# to both parties. See src/modules/whatsapp/ for the integration.
#
# When ANY of the four required vars below is missing, every WhatsApp
# send becomes a no-op — the platform stays up + email + in-app
# notifications still fire. This is the desired dev/preview behaviour.
#
# Provisioning (one-time, ~1–3 days):
#   1. business.facebook.com → create Meta Business Manager
#   2. Add a WhatsApp Business Account (WABA) + verified phone number
#      (cannot be a number already used on personal WhatsApp)
#   3. developers.facebook.com → create an App → add WhatsApp product
#   4. WhatsApp → API Setup → copy Phone Number ID + Business Acct ID
#   5. WhatsApp → Configuration → generate a permanent system-user
#      access token (NOT the temporary 24-hour token)
#   6. WhatsApp → Configuration → set Callback URL to
#      https://api.thecookoncall.com/api/v1/webhooks/whatsapp
#      and Verify Token = whatever you pasted into WHATSAPP_VERIFY_TOKEN
#   7. App → Settings → Basic → copy App Secret into WHATSAPP_APP_SECRET
#   8. WhatsApp → Message Templates → register the 4 templates listed
#      in src/modules/whatsapp/templates.ts (1–24h approval typical)

# Phone number ID — NOT the phone number itself, NOT the WABA ID.
# Found in Meta Business → WhatsApp → API Setup → "Phone number ID".
WHATSAPP_PHONE_NUMBER_ID=

# Permanent system-user access token. Temporary 24-hour tokens will
# break in dev tomorrow morning — generate a permanent one.
WHATSAPP_ACCESS_TOKEN=

# Any random opaque string we choose. Pasted into Meta's webhook
# subscription form so they echo it back during the GET handshake.
# Generate with: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
WHATSAPP_VERIFY_TOKEN=

# Meta App → Settings → Basic → App Secret. Used to HMAC-verify every
# inbound webhook body (Phase 3) — security boundary, treat as a
# top-priority secret.
WHATSAPP_APP_SECRET=

# Optional. Bump only when Meta deprecates the current Graph API
# version (currently v20.0, valid through 2026).
# WHATSAPP_API_VERSION=v20.0

# Optional. Phone numbers stored without a country code (Indian local
# 10-digit format) are prefixed with this when sending. Default is 91
# (India). Override only if you onboard cooks outside India.
# WHATSAPP_DEFAULT_COUNTRY_CODE=91

# ─── SENTRY (Error tracking) ─────────────────────────
# Go to: sentry.io → Create project → Node.js → copy DSN
# Leave empty in dev/local — Sentry init becomes a no-op.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
# Set SENTRY_FORCE=true to enable Sentry locally for testing
SENTRY_FORCE=false
APP_VERSION=1.0.0

# ─── ADMIN AUTO-SEED ─────────────────────────────────
# JSON array of admin accounts to ensure exist on app startup. The seeder
# is idempotent — if the email already exists in the users table, it is
# left untouched (the password is NEVER overwritten by re-seeding). To
# rotate a compromised password, update the row directly in the DB or use
# the password-reset flow; do not rely on this env var for rotation.
#
# If unset or malformed, seeding is silently skipped — leaving this empty
# is safe in production.
#
# Format: a JSON array, single-quoted to keep your shell happy.
#   ADMIN_SEEDS='[{"name":"Admin","email":"admin@example.com","password":"a-long-strong-password"}]'
ADMIN_SEEDS=
