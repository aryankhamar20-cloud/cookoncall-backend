# ═══════════════════════════════════════════════════════
# COOKONCALL BACKEND — ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your real values
# ═══════════════════════════════════════════════════════

# ─── APP ──────────────────────────────────────────────
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# ─── DATABASE (Supabase PostgreSQL) ──────────────────
# Go to: supabase.com → Project → Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres.[YOUR_PROJECT_REF]:[YOUR_DB_PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

# ─── REDIS (Upstash) ─────────────────────────────────
# Go to: console.upstash.com → Create Redis Database → Details tab
REDIS_URL=rediss://default:[YOUR_UPSTASH_PASSWORD]@[YOUR_UPSTASH_ENDPOINT]:6379

# ─── JWT ──────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=PASTE_YOUR_64_CHAR_RANDOM_STRING_HERE
JWT_REFRESH_SECRET=PASTE_ANOTHER_64_CHAR_RANDOM_STRING_HERE
JWT_EXPIRES_IN=15m

# ─── GOOGLE OAUTH ────────────────────────────────────
# Go to: console.cloud.google.com → APIs & Services → Credentials → Create OAuth 2.0 Client
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── RAZORPAY ────────────────────────────────────────
# Go to: dashboard.razorpay.com → Settings → API Keys → Generate Test Key
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ─── MSG91 (OTP & SMS) ───────────────────────────────
# Go to: msg91.com → Dashboard → API Keys
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_OTP_TEMPLATE_ID=your_otp_template_id
MSG91_SMS_TEMPLATE_ID=your_sms_template_id

# ─── CLOUDINARY (Image uploads) ──────────────────────
# Go to: cloudinary.com → Dashboard → Account Details
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── SMTP (Email via Gmail) ──────────────────────────
# Go to: myaccount.google.com → Security → 2-Step Verification → App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_16_char_app_password
SMTP_FROM=noreply@cookoncall.in

# ─── FCM (Firebase Cloud Messaging) ──────────────────
# Go to: console.firebase.google.com → Project Settings → Cloud Messaging → Server Key
FCM_SERVER_KEY=your_fcm_server_key_here

# ─── BREVO (Transactional Email) ─────────────────────
# Already configured above — this reminder is for completeness
# BREVO_API_KEY is the primary email sending mechanism (not SMTP)
BREVO_API_KEY=your_brevo_api_key_here

# ─── SENTRY (Error tracking) ─────────────────────────
# Go to: sentry.io → Create project → Node.js → copy DSN
# Leave empty in dev/local — Sentry init becomes a no-op.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
# Set SENTRY_FORCE=true to enable Sentry locally for testing
SENTRY_FORCE=false
APP_VERSION=1.0.0

# ─── ADMIN AUTO-SEED ─────────────────────────────────
# JSON array of admin accounts to ensure exist on app startup. The seeder
# is idempotent — if the email already exists in the users table, it is
# left untouched (the password is NEVER overwritten by re-seeding). To
# rotate a compromised password, update the row directly in the DB or use
# the password-reset flow; do not rely on this env var for rotation.
#
# If unset or malformed, seeding is silently skipped — leaving this empty
# is safe in production.
#
# Format: a JSON array, single-quoted to keep your shell happy.
#   ADMIN_SEEDS='[{"name":"Admin","email":"admin@example.com","password":"a-long-strong-password"}]'
ADMIN_SEEDS=
